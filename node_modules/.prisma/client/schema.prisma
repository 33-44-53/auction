generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int        @id @default(autoincrement())
  name      String
  email     String     @unique
  password  String
  role      String     @default("VIEWER") // ADMIN | STAFF | VIEWER
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  auditLogs AuditLog[]
}

model Tender {
  id                Int       @id @default(autoincrement())
  title             String?
  tenderNumber      String
  tenderType        String    @default("AUCTION") // AUCTION | HARAJ | YASBELA
  originalTenderId  Int? // Reference to original tender for Yasbela
  harajRound        Int       @default(1) // 1st Haraj, 2nd Haraj, etc.
  date              DateTime? // የተያዘበት ቀን - Catched Date
  location          String? // የተያዘበት ቦታ - Catched Location
  responsibleBody   String? // ያዥው አካል - Responsible body
  exchangeRate      Float
  status            String    @default("OPEN") // OPEN | CLOSED | COMPLETED
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  groups            Group[]
  files             File[]
  originalTender    Tender?   @relation("TenderReference", fields: [originalTenderId], references: [id])
  referencedTenders Tender[]  @relation("TenderReference")

  @@index([status])
  @@index([createdAt])
  @@index([tenderNumber])
}

model Group {
  id              Int       @id @default(autoincrement())
  tenderId        Int
  code            String // "ኮድ-10"
  name            String?
  title           String? // Group-specific title
  date            String? // Group-specific date (የተያዘበት ቀን)
  location        String? // Group-specific location (የተያዘበት ቦታ)
  responsibleBody String? // Group-specific responsible body (ያዥው አካል)
  exchangeRate    Float? // Group-specific exchange rate
  vehiclePlate    String? // የተሸከርካሪ ሰሌዳ - Vehicle plate
  parentGroupId   Int?
  originalGroupId Int? // For Yasbela: reference to the original SOLD group
  basePrice       Float?
  harajPrice      Float? // Simplified price for Haraj (no CIF/FOB/TAX)
  currentRound    String    @default("TAX") // TAX | CIF | FOB | HARAJ
  previousRound   String? // Store previous round before converting to HARAJ (for revert)
  roundNumber     Int       @default(1) // 1, 2, 3
  status          String    @default("OPEN") // OPEN | SOLD | SPLIT | CANCELLED | HARAJ | YASBELA
  winnerBidderId  Int?
  winnerPrice     Float?
  soldPrice       Float?
  yasbelaPenalty  Float? // 5% CPO deduction
  yasbelaReason   String? // Cancellation reason
  yasbelaDate     DateTime? // Date of Yasbela
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tender      Tender        @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  parentGroup Group?        @relation("GroupSplit", fields: [parentGroupId], references: [id])
  childGroups Group[]       @relation("GroupSplit")
  items       Item[]
  bids        Bid[]
  bidders     BidderGroup[]

  @@index([tenderId])
  @@index([status])
  @@index([tenderId, status])
}

model Item {
  id            Int      @id @default(autoincrement())
  groupId       Int
  itemCode      String // 52155
  serialNumber  String? // ተ.ቁ - Serial Number
  name          String
  itemType      String? // የእቃው አይነት - Item Type
  brand         String? // ማርክ - Brand
  country       String? // ስሪት ሀገር - Country of Origin
  unit          String // መለኪያ - Unit
  warehouse1    Int      @default(0) // መጋዘን 1
  warehouse2    Int      @default(0) // መጋዘን 2
  warehouse3    Int      @default(0) // መጋዘን 3
  totalQuantity Int // ጠቅላላ ድምር - Total Quantity
  fob           Float
  cif           Float
  tax           Float
  unitPrice     Float?
  totalPrice    Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
}

model Bidder {
  id          Int           @id @default(autoincrement())
  name        String
  companyName String
  phone       String
  email       String?
  address     String?
  tin         String? // Tax Identification Number
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  bids        Bid[]
  groups      BidderGroup[]
}

model BidderGroup {
  id       Int @id @default(autoincrement())
  bidderId Int
  groupId  Int

  bidder Bidder @relation(fields: [bidderId], references: [id], onDelete: Cascade)
  group  Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([bidderId, groupId])
}

model Bid {
  id          Int      @id @default(autoincrement())
  groupId     Int
  bidderId    Int
  bidPrice    Float
  round       String // TAX | CIF | FOB
  roundNumber Int      @default(1) // 1, 2, 3 for tracking multiple rounds
  isWinner    Boolean  @default(false)
  createdAt   DateTime @default(now())

  group  Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  bidder Bidder @relation(fields: [bidderId], references: [id], onDelete: Cascade)

  @@unique([groupId, bidderId, round])
  @@index([groupId])
  @@index([bidderId])
}

model File {
  id        Int      @id @default(autoincrement())
  tenderId  Int
  filename  String
  path      String
  mimeType  String?
  size      Int?
  createdAt DateTime @default(now())

  tender Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  action    String // LOGIN, UPLOAD, BID, SELECT_WINNER, SPLIT_GROUP, etc.
  entity    String // Tender, Group, Bid, etc.
  entityId  Int?
  details   String? // JSON string for additional details
  ipAddress String?
  timestamp DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([timestamp])
  @@index([entity, entityId])
}
