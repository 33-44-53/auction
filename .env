# Backend runs on 3000, React frontend runs on 5173 (Vite default)
PORT=3000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=https://auction-diredawa.vercel.app

# JWT
JWT_SECRET=tender-management-secret-key-2024-secure
JWT_EXPIRES_IN=24h

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=50MB

# Database
DATABASE_URL=file:./dev.db